# =============================================================================
# CustDevAI — environment variables template
# -----------------------------------------------------------------------------
# Copy this file to .env (`cp .env.example .env`) and fill in real values.
# .env is gitignored — NEVER commit secrets to the repository (NFR-SEC-06).
#
# In production, these values are provided by the cloud platform's secret
# manager (Selectel Secrets, GitHub Actions secrets for CI/CD).
# =============================================================================

# ---------------------------------------------------------------------------
# Application environment
# ---------------------------------------------------------------------------
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
TIMEZONE=Asia/Novosibirsk

# ---------------------------------------------------------------------------
# PostgreSQL credentials (FR-DB-01..08, NFR-OPS-01)
# ---------------------------------------------------------------------------
POSTGRES_USER=custdev
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
POSTGRES_DB=custdevai
POSTGRES_PORT=5432

# Full connection URL (auto-composed in docker-compose, override only if needed)
# DATABASE_URL=postgresql+asyncpg://custdev:password@postgres:5432/custdevai

# ---------------------------------------------------------------------------
# Redis (Celery broker + aiogram FSM storage)
# ---------------------------------------------------------------------------
REDIS_PORT=6379
# REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# API service ports
# ---------------------------------------------------------------------------
API_PORT=8000
WEB_PORT=5173

# ---------------------------------------------------------------------------
# Telegram bot (FR-BOT-*, NFR-SEC-06)
# -----------------------------------------------------------------------------
# Get a token by talking to @BotFather in Telegram.
# Use a SEPARATE bot for development and production — never share tokens.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_WEBHOOK_SECRET=replace-with-random-32-byte-hex
TELEGRAM_WEBHOOK_URL=                     # leave empty for long-polling in dev

# Optional second bot used for researcher push-notifications (FR-BOT-09).
# Reuses the main token if not set.
TELEGRAM_NOTIFY_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Authentication / JWT (FR-AUTH-03..04, NFR-SEC-02..03)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-character-random-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# bcrypt cost factor — must be ≥ 12 per NFR-SEC-02. Higher = slower but safer.
BCRYPT_COST_FACTOR=12

# ---------------------------------------------------------------------------
# Pseudonymization salt (FR-DB-03, FR-BOT-10)
# ---------------------------------------------------------------------------
# Per-deployment master salt. Per-campaign salts are derived from it via HKDF.
# Generate with: openssl rand -hex 32
PSEUDONYM_MASTER_SALT=replace-with-64-character-random-hex-string

# ---------------------------------------------------------------------------
# ML modules configuration (FR-SENT-*, FR-TOP-*)
# ---------------------------------------------------------------------------
# Sentiment analysis (RuBERT)
SENTIMENT_MODEL_NAME=DeepPavlov/rubert-base-cased
SENTIMENT_CONFIDENCE_THRESHOLD=0.5         # FR-SENT-05; below this → "low confidence"
SENTIMENT_RANDOM_SEED=42                   # FR-SENT-04: deterministic results
SENTIMENT_BATCH_SIZE=16

# Topic modeling (BERTopic)
TOPIC_EMBEDDER_NAME=intfloat/multilingual-e5-base
TOPIC_DEFAULT_COUNT=10                     # FR-TOP-04; user-tunable in 3..20
TOPIC_MIN_COUNT=3
TOPIC_MAX_COUNT=20
TOPIC_RANDOM_SEED=42                       # FR-TOP-07: deterministic clustering

# Cache directory for downloaded HuggingFace weights (mapped to a docker volume)
ML_MODEL_CACHE_DIR=/models
TRANSFORMERS_OFFLINE=0                     # set to 1 in air-gapped environments

# Hard guarantee: NEVER set any external LLM API keys here. Sending interview
# data to third parties violates FR-SENT-08 and NFR-SEC-09. ML runs strictly
# locally. If you find a tutorial recommending OpenAI/Anthropic API integration
# for sentiment, IGNORE it — it does not apply to this project.

# ---------------------------------------------------------------------------
# Performance tuning (NFR-PRF-*)
# ---------------------------------------------------------------------------
# Maximum concurrent interview sessions (NFR-PRF-06)
MAX_CONCURRENT_SESSIONS=50

# Session timeout for asynchronous interview pause-and-resume (FR-BOT-05)
SESSION_TIMEOUT_HOURS=48

# Page size for paginated API endpoints (NFR-PRF-03)
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

# ---------------------------------------------------------------------------
# Phase 4: Reports + Web (FR-RPT-01..08, FR-WEB-01..12)
# ---------------------------------------------------------------------------
# Локальное хранилище сгенерированных PDF/XLSX-отчётов. В docker-compose
# монтируется как именованный том reports_storage. Phase 5 заменит на S3.
REPORTS_STORAGE_DIR=/var/lib/custdevai/reports

# Базовый URL веб-панели — попадает во второй push «ML-анализ завершён»
# (FR-BOT-09). В dev — Vite dev server. В prod — Nginx-домен.
WEB_BASE_URL=http://localhost:5173

# CORS-домены SPA с credentials=include. Список через запятую.
CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# httpOnly cookies для JWT (set_cookie=true на /auth/login).
# Если COOKIE_SECURE пуст — auto: True в production, False в dev.
# COOKIE_SECURE=true
COOKIE_SAMESITE=strict

# ---------------------------------------------------------------------------
# Phase 5: backups, sweepers, ML training, SMTP, production deploy
# ---------------------------------------------------------------------------
# FR-DB-08 / NFR-REL-03/05/06: ежедневный pg_dump в этот каталог через
# Celery beat. В docker-compose смонтирован как volume backups_storage.
# Хранятся последние BACKUP_RETENTION_COUNT копий, старые удаляются.
BACKUP_STORAGE_DIR=/var/lib/custdevai/backups
BACKUP_RETENTION_COUNT=7

# FR-BOT-05: sweeper переводит active → interrupted после стольких часов
# неактивности. По спецификации — 48 часов.
SESSION_INACTIVE_HOURS=48

# FR-SENT-07: путь к fine-tuned RuBERT-весам (output apps/ml/sentiment/training).
# Пусто → используется baseline DeepPavlov/rubert-base-cased без дообучения.
# SENTIMENT_MODEL_PATH=/models/rubert-finetuned

# FR-AUTH-06: SMTP для доставки временных паролей при сбросе. Если SMTP_HOST
# пуст — фабрика выбирает LoggingEmailNotifier (только лог-запись).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@custdevai.local
SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# Selectel cloud (production deployment)
# ---------------------------------------------------------------------------
# Used by deployment scripts only — leave empty in development.
SELECTEL_ACCOUNT_ID=
SELECTEL_OBJECT_STORAGE_KEY=               # for storing generated reports (FR-RPT-08)
SELECTEL_OBJECT_STORAGE_SECRET=
SELECTEL_OBJECT_STORAGE_BUCKET=custdevai-reports
SELECTEL_OBJECT_STORAGE_ENDPOINT=https://s3.storage.selcloud.ru

# ---------------------------------------------------------------------------
# Observability (optional but recommended for production)
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=${ENVIRONMENT}

# ---------------------------------------------------------------------------
# Feature flags (development conveniences — never enable in production)
# ---------------------------------------------------------------------------
# Skip phone-format validation, allow weak passwords, etc.
DEBUG_AUTH_BYPASS=false
DEBUG_DETERMINISTIC_PSEUDONYMS=false
